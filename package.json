{
  "name": "@wordbricks/persona",
  "version": "0.1.1",
  "description": "Brain-inspired persona memory and runtime for LLM agents on Postgres/pgvector via Drizzle.",
  "keywords": [
    "agents",
    "ai",
    "drizzle",
    "embeddings",
    "llm",
    "memory",
    "persona",
    "pgvector",
    "postgres"
  ],
  "license": "Apache-2.0",
  "author": "Wordbricks, Inc.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js",
      "default": "./dist/schema/index.js"
    },
    "./memory": {
      "types": "./dist/memory/index.d.ts",
      "import": "./dist/memory/index.js",
      "default": "./dist/memory/index.js"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "import": "./dist/agent/index.js",
      "default": "./dist/agent/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "NOTICE",
    "README.md",
    "ARCHITECTURE.md",
    "RESPONSIBLE_USE.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wordbricks/persona.git"
  },
  "homepage": "https://github.com/wordbricks/persona#readme",
  "bugs": "https://github.com/wordbricks/persona/issues",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "ulid": "3.0.2",
    "zod": "4.3.5"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/pg": "8.16.0",
    "drizzle-orm": "0.45.2",
    "pg": "8.17.1",
    "postgres": "3.4.8",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.0"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.45.2"
  }
}
